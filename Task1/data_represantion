; data_representation.asm
; Demonstrates bytes, words and doublewords

section .data

    title db "=== Data Representation Demo ===",10
    titleLen equ $-title

    byteChar db 'A'
    newline db 10

    wordValue dw 12345
    dwordValue dd 123456789

    msg1 db "Byte (ASCII): ",0
    msg1Len equ 14

section .text
    global _start

_start:

    ; Print title

    mov rax,1
    mov rdi,1
    mov rsi,title
    mov rdx,titleLen
    syscall

    ; Print label

    mov rax,1
    mov rdi,1
    mov rsi,msg1
    mov rdx,msg1Len
    syscall

    ; Print ASCII character

    mov rax,1
    mov rdi,1
    mov rsi,byteChar
    mov rdx,1
    syscall

    ; New line

    mov rax,1
    mov rdi,1
    mov rsi,newline
    mov rdx,1
    syscall

    ; Exit

    mov rax,60
    xor rdi,rdi
    syscall
